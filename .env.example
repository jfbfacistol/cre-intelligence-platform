# =============================================================================
# CRE Market Intelligence Platform — Environment Variables Template
# =============================================================================
#
# SETUP INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your actual values in the new .env file
#   3. NEVER commit .env to Git — it is protected by .gitignore
#
# ARCHITECTURE:
#   This file serves as the Single Source of Truth for:
#   - Docker Compose (Container orchestration)
#   - Terraform (Infrastructure as Code)
#   - Mage.ai (Data Engineering pipelines)
#   - dbt (Analytics Engineering transformations)
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Data Warehouse
# -----------------------------------------------------------------------------
POSTGRES_DB=cre_db
POSTGRES_USER=cre_user
POSTGRES_PASSWORD=replace_with_your_secure_password
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Mage.ai Orchestration
# -----------------------------------------------------------------------------
MAGE_PORT=6789
MAGE_PROJECT_NAME=cre_platform

# -----------------------------------------------------------------------------
# dbt Transformation Layer
# -----------------------------------------------------------------------------
# Note: Use 'localhost' for local dbt runs, or 'cre_postgres' for Docker-based runs.
DBT_POSTGRES_HOST=localhost
DBT_POSTGRES_PORT=5432
DBT_POSTGRES_DB=cre_db
DBT_POSTGRES_USER=cre_user
DBT_POSTGRES_PASSWORD=replace_with_your_secure_password
DBT_POSTGRES_SCHEMA=gold

# -----------------------------------------------------------------------------
# Terraform (Infrastructure Variables)
# -----------------------------------------------------------------------------
TF_VAR_db_name=cre_db
TF_VAR_db_user=cre_user
TF_VAR_db_password=replace_with_your_secure_password
TF_VAR_postgres_port=5432
TF_VAR_mage_port=6789

# -----------------------------------------------------------------------------
# Data Ingestion Config
# -----------------------------------------------------------------------------
# Ensure the CSV exists in your ./data/ directory
CSV_FILENAME=australian_rental_market_2026.csv